            "type": "integer",
            "title": "Product Id"
          },
          "threshold_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Threshold Price"
          },
          "direction": {
            "$ref": "#/components/schemas/AlertDirection"
          },
          "is_active": {
            "type": "boolean",
