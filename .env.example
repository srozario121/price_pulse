# =============================================================================
# Price Pulse — environment variables
# Copy this file to .env and fill in your values.
# All variables are loaded by Docker Compose from the repo root.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend — Database
# ---------------------------------------------------------------------------
# Async Postgres connection URL (used by SQLAlchemy + Alembic)
DATABASE_URL=postgresql+asyncpg://price_pulse:price_pulse@postgres:5432/price_pulse

# Synchronous URL — used only by Alembic migration runner (not the app)
DATABASE_SYNC_URL=postgresql://price_pulse:price_pulse@postgres:5432/price_pulse

# Postgres superuser credentials (used by the postgres service container)
POSTGRES_USER=price_pulse
POSTGRES_PASSWORD=price_pulse
POSTGRES_DB=price_pulse

# ---------------------------------------------------------------------------
# Backend — Redis / Celery
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---------------------------------------------------------------------------
# Backend — Application
# ---------------------------------------------------------------------------
# Must be changed in production; generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Set to "true" to enable FastAPI debug mode (never in production)
DEBUG=false

# Required in production (DEBUG=false). JSON list of allowed origins.
# pydantic-settings v2 JSON-decodes complex fields from env vars, so use JSON array syntax.
# Example for production: CORS_ORIGINS=["https://app.example.com"]
CORS_ORIGINS=["http://localhost"]

# Interval between scheduled scrapes for each product (minutes)
SCRAPE_INTERVAL_MINUTES=30

# Alert cooldown — minimum hours between repeat notifications for the same alert
ALERT_COOLDOWN_HOURS=24

# Minimum delay (seconds) between requests to the same domain (rate limiting)
SCRAPE_MIN_DELAY_SECONDS=2

# Structlog log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Frontend (Vite build-time variables — must be prefixed with VITE_)
# ---------------------------------------------------------------------------
# Base URL that the React SPA uses to reach the backend API
VITE_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# pgAdmin (dev only — docker-compose.dev.yml)
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@pricepulse.local
PGADMIN_DEFAULT_PASSWORD=admin
