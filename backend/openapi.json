          "threshold_price",
          "direction",
          "id"
        ],
        "title": "AlertRead"
      },
      "AlertUpdate": {
        "properties": {
          "threshold_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Threshold Price"
          },
          "direction": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AlertDirection"
              },
              {
                "type": "null"
              }
            ]
          },
          "is_active": {
            "anyOf": [
              {
                "type": "boolean"
              },
